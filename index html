  const checkGameHit = (note) => {
    // Find closest note to the hitting bottom zone (around y=450 to y=520)
    let closestNote = null;
    let minDistance = 9999;

    gameNotes.forEach(n => {
      if (!n.hasHit && n.note === note && Math.abs(n.y - 480) < 120) {
        const distance = Math.abs(n.y - 480);
        if (distance < minDistance) {
          minDistance = distance;
          closestNote = n;
        }
      }
    });

    if (closestNote) {
      // Determine Hit quality
      let feedback = 'MISS';
      let addedScore = 0;

      if (minDistance < 25) {
        feedback = 'SEMPURNA!';
        addedScore = 150;
      } else if (minDistance < 60) {
        feedback = 'BAGUS!';
        addedScore = 80;
      } else if (minDistance < 100) {
        feedback = 'CUKUP!';
        addedScore = 40;
      }

      setGameFeedback(feedback);
      if (feedback !== 'MISS') {
        setGameScore(prev => prev + addedScore + gameCombo * 10);
        setGameCombo(prev => {
          const next = prev + 1;
          if (next > gameMaxCombo) setGameMaxCombo(next);
          return next;
        });
      } else {
        setGameCombo(0);
      }

      setGameNotes(prev => prev.map(n => n.id === closestNote.id ? { ...n, hasHit: true, y: 1000 } : n));
    }
