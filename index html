// AUDIO SYNTHESIZER (Web Audio API)
// ==========================================
class SoundSynth {
  constructor() {
    this.ctx = null;
    this.activeNodes = {};
  }

  init() {
    if (!this.ctx) {
      this.ctx = new (window.AudioContext || window.webkitAudioContext)();
    }
    if (this.ctx.state === 'suspended') {
      this.ctx.resume();
    }
  }

  playNote(frequency, instrument = 'piano', volume = 0.5) {
    this.init();
    const ctx = this.ctx;
    const osc = ctx.createOscillator();
    const gainNode = ctx.createGain();
    
    osc.connect(gainNode);
    gainNode.connect(ctx.destination);

    const now = ctx.currentTime;

    if (instrument === 'piano') {
      // Acoustic Piano Synth Modeling
      osc.type = 'sine';
      
      // Overtones for piano richness
      const overtone1 = ctx.createOscillator();
      const overtoneNode1 = ctx.createGain();
      overtone1.type = 'triangle';
      overtone1.frequency.setValueAtTime(frequency * 2, now);
      overtoneNode1.gain.setValueAtTime(volume * 0.25, now);
      overtone1.connect(overtoneNode1);
      overtoneNode1.connect(ctx.destination);
      overtone1.start(now);
      overtone1.stop(now + 1.5);
      overtoneNode1.gain.exponentialRampToValueAtTime(0.001, now + 1.2);

      const overtone2 = ctx.createOscillator();
      const overtoneNode2 = ctx.createGain();
      overtone2.type = 'sine';
      overtone2.frequency.setValueAtTime(frequency * 3, now);
      overtoneNode2.gain.setValueAtTime(volume * 0.15, now);
      overtone2.connect(overtoneNode2);
      overtoneNode2.connect(ctx.destination);
      overtone2.start(now);
      overtone2.stop(now + 1.0);
      overtoneNode2.gain.exponentialRampToValueAtTime(0.001, now + 0.9);

      // Main Note Envelope
      osc.frequency.setValueAtTime(frequency, now);
      // Sharp attack, rapid decay, exponential release
      gainNode.gain.setValueAtTime(0, now);
      gainNode.gain.linearRampToValueAtTime(volume * 0.8, now + 0.01);
      gainNode.gain.exponentialRampToValueAtTime(volume * 0.4, now + 0.3);
      gainNode.gain.exponentialRampToValueAtTime(0.001, now + 2.0);
      
      osc.start(now);
      osc.stop(now + 2.0);

      this.activeNodes[frequency] = { oscs: [osc, overtone1, overtone2], gains: [gainNode, overtoneNode1, overtoneNode2] };
    } 
    else if (instrument === 'organ') {
      // Hammond Organ Style Synth
      osc.type = 'sawtooth';
      
      const subOsc = ctx.createOscillator();
      const subGain = ctx.createGain();
      subOsc.type = 'sine';
      subOsc.frequency.setValueAtTime(frequency * 0.5, now);
      subGain.gain.setValueAtTime(volume * 0.4, now);
      subOsc.connect(subGain);
      subGain.connect(ctx.destination);
      subOsc.start(now);
      subOsc.stop(now + 1.5);
      subGain.gain.exponentialRampToValueAtTime(0.001, now + 1.4);

      osc.frequency.setValueAtTime(frequency, now);
      gainNode.gain.setValueAtTime(0, now);
      gainNode.gain.linearRampToValueAtTime(volume * 0.6, now + 0.05);
      gainNode.gain.exponentialRampToValueAtTime(volume * 0.3, now + 0.8);
      gainNode.gain.exponentialRampToValueAtTime(0.001, now + 1.5);

      osc.start(now);
      osc.stop(now + 1.5);

      this.activeNodes[frequency] = { oscs: [osc, subOsc], gains: [gainNode, subGain] };
    } 
    else if (instrument === 'synth') {
      // Warm electronic synth / violin-ish string feel
      osc.type = 'triangle';
      
      // Adding mild LFO (Vibrato)
      const lfo = ctx.createOscillator();
      const lfoGain = ctx.createGain();
      lfo.frequency.setValueAtTime(6, now); // 6Hz vibrato
      lfoGain.gain.setValueAtTime(5, now); // vibrato depth
      lfo.connect(lfoGain);
      lfoGain.connect(osc.frequency);
      lfo.start(now);
      lfo.stop(now + 2.0);

      osc.frequency.setValueAtTime(frequency, now);
      gainNode.gain.setValueAtTime(0, now);
      gainNode.gain.linearRampToValueAtTime(volume * 0.7, now + 0.15); // slower attack
      gainNode.gain.exponentialRampToValueAtTime(volume * 0.5, now + 0.6);
      gainNode.gain.exponentialRampToValueAtTime(0.001, now + 2.0);

      osc.start(now);
      osc.stop(now + 2.0);

      this.activeNodes[frequency] = { oscs: [osc, lfo], gains: [gainNode, lfoGain] };
    }
  }

  stopNote(frequency) {
    // Graceful fadeout when released
    if (this.activeNodes[frequency] && this.ctx) {
      const now = this.ctx.currentTime;
      this.activeNodes[frequency].gains.forEach(gainNode => {
        try {
          gainNode.gain.cancelScheduledValues(now);
          gainNode.gain.setValueAtTime(gainNode.gain.value, now);
          gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.2);
        } catch (e) {}
      });
      setTimeout(() => {
        try {
          this.activeNodes[frequency]?.oscs.forEach(osc => osc.stop());
        } catch (e) {}
        delete this.activeNodes[frequency];
      }, 200);
    }
  }
}

