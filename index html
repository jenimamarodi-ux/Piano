      const systemPrompt = `Anda adalah asisten virtual ahli piano. Berikan saran progres akor, melodi indah, dan tips latihan berdasarkan mood lagu yang dipilih oleh pengguna. Format respon Anda dalam JSON terstruktur dengan kunci: 'rekomendasi_judul' (string), 'progresi' (string), 'nada_melodi' (array berisi not seperti C4, E4, G4, dsb), 'tips' (string). Jawab dalam Bahasa Indonesia.`;
      const userPrompt = `Saya ingin membuat melodi piano yang mengekspresikan mood: '${aiMood}'. Berikan usulan notasi yang bisa saya mainkan di keyboard virtual saya beserta panduan belajar yang mudah!`;

      const payload = {
        contents: [{ parts: [{ text: userPrompt }] }],
        systemInstruction: { parts: [{ text: systemPrompt }] },
        generationConfig: { 
          responseMimeType: "application/json",
          responseSchema: {
            type: "OBJECT",
            properties: {
              rekomendasi_judul: { type: "STRING" },
              progresi: { type: "STRING" },
              nada_melodi: { type: "ARRAY", items: { type: "STRING" } },
              tips: { type: "STRING" }
            },
            required: ["rekomendasi_judul", "progresi", "nada_melodi", "tips"]
          }
        }
      };

      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      const result = await response.json();
      const rawText = result.candidates?.[0]?.content?.parts?.[0]?.text;
      
      if (rawText) {
        const parsed = JSON.parse(rawText);
        setAiMelodyResult(parsed);
        setAiAdvice(`Berikut adalah inspirasi lagu "${parsed.rekomendasi_judul}" dengan progresi akor: ${parsed.progresi}.`);
      } else {
        setAiAdvice("Maaf, AI gagal menyusun melodi. Coba pilih mood lain.");
      }
    } catch (error) {
      console.error("AI Error:", error);
      setAiAdvice("Koneksi gagal saat menghubungi asisten AI Anda. Silakan coba kembali beberapa saat lagi.");
    } finally {
      setIsAiLoading(false);
    }
  };

