  // ==========================================
  // RENDER DETAILED PIANO KEYBOARD COMPONENT
  // ==========================================
  const renderPianoKeyboard = (highlightedNote = null) => {
    return (
      <div className="relative bg-slate-950 p-4 rounded-2xl border border-slate-800 overflow-hidden shadow-2xl">
        {/* Scroll helper icons on side */}
        <div className="flex justify-between items-center mb-2.5 text-xs text-slate-400">
          <span>Geser kiri/kanan jika tuts terpotong pada layar ponsel</span>
          <div className="flex gap-2">
            <button 
              onClick={() => keyboardScrollRef.current.scrollBy({ left: -200, behavior: 'smooth' })}
              className="p-1 bg-slate-800 hover:bg-slate-700 rounded text-white"
            >
              ◀️
            </button>
            <button 
              onClick={() => keyboardScrollRef.current.scrollBy({ left: 200, behavior: 'smooth' })}
              className="p-1 bg-slate-800 hover:bg-slate-700 rounded text-white"
            >
              ▶️
            </button>
          </div>
        </div>

        {/* Outer scroll container */}
        <div 
          ref={keyboardScrollRef}
          className="flex overflow-x-auto select-none pb-4 relative custom-scrollbar scroll-smooth"
          style={{ minHeight: '220px' }}
        >
          {pianoNotes.map((note) => {
            const isBlack = isBlackKey(note);
            const isPressed = activePianoKeys[note];
            const isTarget = highlightedNote === note;

            if (isBlack) {
              // Black Keys rendering (positioned floating above white keys using absolute overlap styling is trickier, so we use a robust overlapping inline layout)
              return (
                <div 
                  key={note}
                  onMouseDown={() => handleNotePress(note)}
                  onMouseUp={() => handleNoteRelease(note)}
                  onMouseLeave={() => handleNoteRelease(note)}
                  onTouchStart={(e) => { e.preventDefault(); handleNotePress(note); }}
                  onTouchEnd={(e) => { e.preventDefault(); handleNoteRelease(note); }}
                  className={`z-20 -mx-3 h-32 w-6 rounded-b transition-all duration-75 cursor-pointer relative ${isPressed ? 'bg-indigo-600 h-32 shadow-inner' : isTarget ? 'bg-emerald-500 h-32 shadow-[0_0_8px_#10b981]' : 'bg-slate-900 border-l border-r border-slate-950'}`}
                  style={{ minWidth: '24px' }}
                >
                  <span className="absolute bottom-1.5 left-0 right-0 text-[8px] font-bold text-center text-slate-400 font-mono">
                    {note}
                  </span>
                </div>
              );
            } else {
              // White Keys rendering
              return (
                <div 
                  key={note}
                  onMouseDown={() => handleNotePress(note)}
                  onMouseUp={() => handleNoteRelease(note)}
                  onMouseLeave={() => handleNoteRelease(note)}
                  onTouchStart={(e) => { e.preventDefault(); handleNotePress(note); }}
                  onTouchEnd={(e) => { e.preventDefault(); handleNoteRelease(note); }}
                  className={`h-48 w-11 rounded-b border-b-4 border-l border-r border-slate-200 transition-all duration-75 cursor-pointer flex flex-col justify-end pb-3 items-center relative ${isPressed ? 'bg-indigo-100 border-b-2 h-48 shadow-inner' : isTarget ? 'bg-emerald-100 border-b-emerald-400 border-b-2 h-48 shadow-[inset_0_0_12px_#10b981]' : 'bg-white hover:bg-slate-50'}`}
                  style={{ minWidth: '44px' }}
                >
                  {/* Highlights targeted key */}
                  {isTarget && (
                    <div className="absolute top-0 left-0 right-0 h-4 bg-emerald-500 animate-pulse" />
                  )}
                  <span className={`text-[10px] font-bold font-mono tracking-tighter ${isPressed ? 'text-indigo-800' : isTarget ? 'text-emerald-800' : 'text-slate-600'}`}>
                    {note}
                  </span>
                </div>
              );
            }
          })}
        </div>
      </div>
    );
  };

  // Main Return Layout
  return (
    <div className={`min-h-screen transition-colors duration-200 ${darkMode ? 'bg-slate-900 text-slate-100' : 'bg-slate-50 text-slate-900'}`}>
      
      {/* Top Navbar Header */}
      <header className="border-b border-slate-800 bg-slate-950/80 sticky top-0 z-50 backdrop-blur-md px-4 py-3 flex justify-between items-center">
        <div className="flex items-center gap-2.5 cursor-pointer" onClick={() => setActiveTab('home')}>
          <span className="text-3xl">🎹</span>
          <div>
            <h1 className="font-black text-lg tracking-wider text-white">VIRTUAL PIANO</h1>
            <p className="text-[10px] text-indigo-400 font-bold uppercase tracking-widest leading-none">PRO STUDIO</p>
          </div>
        </div>

        {/* Center Nav Items */}
        <nav className="hidden lg:flex items-center gap-1">
          {[
            { id: 'home', label: 'Beranda', icon: '🏠' },
            { id: 'play', label: 'Main Piano', icon: '🎹' },
            { id: 'learn', label: 'Belajar Lagu', icon: '🎵' },
            { id: 'game', label: 'Mode Game', icon: '🎮' },
            { id: 'multiplayer', label: 'Multiplayer', icon: '👥' },
            { id: 'ai', label: 'Piano AI', icon: '🤖' },
            { id: 'leaderboard', label: 'Leaderboard', icon: '🏆' },
          ].map(tab => (
            <button 
              key={tab.id}
              onClick={() => setActiveTab(tab.id)}
              className={`px-3.5 py-1.5 rounded-lg text-xs font-bold transition flex items-center gap-1.5 ${activeTab === tab.id ? 'bg-indigo-600 text-white' : 'text-slate-400 hover:bg-slate-900 hover:text-slate-200'}`}
            >
              <span>{tab.icon}</span>
              {tab.label}
            </button>
          ))}
        </nav>

        {/* User status & options */}
        <div className="flex items-center gap-3">
          <div className="text-right hidden sm:block">
            <div className="text-xs font-bold text-slate-200">{username}</div>
            <div className="text-[10px] text-emerald-400 flex items-center gap-1 justify-end">
              <span className="h-1.5 w-1.5 rounded-full bg-emerald-400 inline-block animate-pulse"></span> Online
            </div>
          </div>
          <button 
            onClick={() => setActiveTab('settings')}
            className="p-2 rounded-lg bg-slate-900 hover:bg-slate-800 border border-slate-800 text-sm"
            title="Pengaturan"
          >
            ⚙️
          </button>
        </div>
      </header>

      {/* Main App Workspace Container */}
      <main className="max-w-7xl mx-auto p-4 md:p-6 pb-24">
        {renderTabContent()}
      </main>

      {/* Mobile Sticky Bottom Navigation Bar */}
      <footer className="lg:hidden fixed bottom-0 left-0 right-0 bg-slate-950/95 border-t border-slate-800 p-2 z-50 flex justify-around">
        {[
          { id: 'home', label: 'Home', icon: '🏠' },
          { id: 'play', label: 'Piano', icon: '🎹' },
          { id: 'learn', label: 'Belajar', icon: '🎵' },
          { id: 'game', label: 'Game', icon: '🎮' },
          { id: 'multiplayer', label: 'M-Player', icon: '👥' },
          { id: 'ai', label: 'AI', icon: '🤖' },
        ].map(tab => (
          <button 
            key={tab.id}
            onClick={() => setActiveTab(tab.id)}
            className={`flex flex-col items-center p-1.5 rounded text-[10px] font-bold ${activeTab === tab.id ? 'text-indigo-400' : 'text-slate-400'}`}
          >
            <span className="text-base mb-0.5">{tab.icon}</span>
            {tab.label}
          </button>
        ))}
      </footer>
    </div>
  );
}