  // Multiplayer State
  const [roomList, setRoomList] = useState([]);
  const [activeRoom, setActiveRoom] = useState(null);
  const [roomPlayers, setRoomPlayers] = useState([]);
  const [roomMessages, setRoomMessages] = useState([]);
  const [chatInput, setChatInput] = useState('');
  const [roomNameInput, setRoomNameInput] = useState('');

  // AI Assistant State
  const [aiMood, setAiMood] = useState('ceria');
  const [aiMelodyResult, setAiMelodyResult] = useState('');
  const [aiEvaluation, setAiEvaluation] = useState('');
  const [isAiLoading, setIsAiLoading] = useState(false);
  const [aiAdvice, setAiAdvice] = useState('Halo! Saya asisten pianis AI Anda. Pilih mood Anda di bawah dan saya akan merekomendasikan melodi indah!');

  // References
  const keyboardScrollRef = useRef(null);
  const gameLoopRef = useRef(null);
  const metronomeIntervalRef = useRef(null);

  // Determine current active octave layout
  const pianoNotes = useMemo(() => {
    if (keyboardSize === 88) return ALL_NOTES_88;
    if (keyboardSize === 61) return ALL_NOTES_61;
    return ALL_NOTES_36;
  }, [keyboardSize]);

  // Handle Firebase User Authentication on mount
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) {
        console.error("Auth error:", err);
      }
    };
    initAuth();

    const unsubscribe = onAuthStateChanged(auth, (usr) => {
      if (usr) {
        setUser(usr);
        // Set Default Display Name
        const randomId = usr.uid.substring(0, 5);
        setUsername(`Pianis_${randomId}`);
      }
    });

    return () => unsubscribe();
  }, []);

  // Listen for Multiplayer Lobby Rooms (Firestore Rule 1 & Rule 3 compliant)
  useEffect(() => {
    if (!user) return;

    const roomsCollection = collection(db, 'artifacts', appId, 'public', 'data', 'pianoRooms');
    const unsubscribe = onSnapshot(roomsCollection, (snapshot) => {
      const rooms = [];
      snapshot.forEach((doc) => {
        rooms.push({ id: doc.id, ...doc.data() });
      });
      setRoomList(rooms);
    }, (err) => {
      console.error("Room sync error:", err);
    });

    return () => unsubscribe();
  }, [user]);

  // Listen to Active Room State (Players & Chat)
  useEffect(() => {
    if (!user || !activeRoom) return;

    // Track active room player list and chats
    const roomRef = doc(db, 'artifacts', appId, 'public', 'data', 'pianoRooms', activeRoom.id);
    const unsubscribeRoom = onSnapshot(roomRef, (snapshot) => {
      if (snapshot.exists()) {
        const data = snapshot.data();
        setRoomPlayers(data.players || []);
        setRoomMessages(data.chats || []);
      }
    }, (err) => console.error("Room sync error:", err));

    return () => unsubscribeRoom();
  }, [user, activeRoom]);

  // Metronome Sound Engine
  useEffect(() => {
    if (metronomeOn) {
      const intervalMs = (60 / bpm) * 1000;
      metronomeIntervalRef.current = setInterval(() => {
        setMetronomeBeat(prev => {
          const nextBeat = (prev % 4) + 1;
          // Play click sound using Audio Context
          try {
            synth.playNote(nextBeat === 1 ? 880 : 440, 'synth', 0.2);
          } catch(e) {}
          return nextBeat;
        });
      }, intervalMs);
    } else {
      clearInterval(metronomeIntervalRef.current);
      setMetronomeBeat(0);
    }

    return () => clearInterval(metronomeIntervalRef.current);
  }, [metronomeOn, bpm]);

  // Computer Keyboard Keydown Handler
  useEffect(() => {
    const handleKeyDown = (e) => {
      // Prevent mapping keys if writing in chat input
      if (document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA') {
        return;
      }
      const char = e.key.toLowerCase();
      if (KEY_MAP[char]) {
        const note = KEY_MAP[char];
        handleNotePress(note);
      }
    };

    const handleKeyUp = (e) => {
      const char = e.key.toLowerCase();
      if (KEY_MAP[char]) {
        const note = KEY_MAP[char];
        handleNoteRelease(note);
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    window.addEventListener('keyup', handleKeyUp);
    return () => {
      window.removeEventListener('keydown', handleKeyDown);
      window.removeEventListener('keyup', handleKeyUp);
    };
  }, [activePianoKeys, activeTab, selectedSong, currentStep]);

  // ==========================================
  // CORE AUDIO HANDLERS
  // ==========================================
  const handleNotePress = (note) => {
    if (activePianoKeys[note]) return; // Avoid retriggering

    const freq = NOTE_FREQS[note];
    if (freq) {
      synth.playNote(freq, instrument, volume);
      setActivePianoKeys(prev => ({ ...prev, [note]: true }));

      // Record logic
      if (isRecording) {
        const timeOffset = Date.now() - recordingStartTime;
        setRecordedNotes(prev => [...prev, { note, time: timeOffset, action: 'down' }]);
      }

      // Learn Mode progression
      if (activeTab === 'learn' && selectedSong && !learnComplete) {
        const targetNote = selectedSong.notes[currentStep].note;
        if (note === targetNote) {
          // Correct note hit
          const nextStep = currentStep + 1;
          if (nextStep >= selectedSong.notes.length) {
            setLearnComplete(true);
            calculateLearnScore();
          } else {
            setCurrentStep(nextStep);
          }
        } else {
          // Wrong note hit
          setWrongPressCount(prev => prev + 1);
          setLearnScore(prev => Math.max(20, prev - 5));
        }
      }

      // Rhythm Game hit detection
      if (activeTab === 'game' && gamePlaying) {
        checkGameHit(note);
      }

      // Multiplayer Live Action
      if (activeTab === 'multiplayer' && activeRoom) {
        broadcastMultiplayerKey(note, true);
      }
    }
  };

  const handleNoteRelease = (note) => {
    const freq = NOTE_FREQS[note];
    if (freq) {
      synth.stopNote(freq);
      setActivePianoKeys(prev => {
        const updated = { ...prev };
        delete updated[note];
        return updated;
      });

      // Record Logic Stop
      if (isRecording) {
        const timeOffset = Date.now() - recordingStartTime;
        setRecordedNotes(prev => [...prev, { note, time: timeOffset, action: 'up' }]);
      }

      // Multiplayer Live Action Release
      if (activeTab === 'multiplayer' && activeRoom) {
        broadcastMultiplayerKey(note, false);
      }
    }
  };

  // ==========================================
  // LEARN MODE LOGIC
  // ==========================================
  const startLearnSong = (song) => {
    setSelectedSong(song);
    setCurrentStep(0);
    setLearnScore(100);
    setWrongPressCount(0);
    setLearnComplete(false);
  };

  const calculateLearnScore = () => {
    const totalNotes = selectedSong.notes.length;
    const accuracy = Math.max(0, Math.round(((totalNotes - wrongPressCount) / totalNotes) * 100));
    setLearnAccuracy(accuracy);
  };

  // ==========================================
  // RHYTHM GAME LOGIC
  // ==========================================
  const startGame = (track) => {
    setSelectedTrack(track);
    setGamePlaying(true);
    setGameScore(0);
    setGameCombo(0);
    setGameMaxCombo(0);
    setGameFeedback('');
    
    // Scale speed multiplier by difficulty
    const speedMult = difficulty === 'mudah' ? 1.0 : difficulty === 'sedang' ? 1.5 : 2.2;
    
    // Process falling notes data
    const notesToRun = track.notes.map((n, i) => ({
      id: i,
      note: n.note,
      y: -100 - (n.time * 250 * speedMult), // Stack notes vertically depending on timestamps
      hasHit: false
    }));
    setGameNotes(notesToRun);

    // Main Game Animation Loop
    let lastTime = performance.now();
    const runLoop = (now) => {
      const delta = (now - lastTime) / 1000;
      lastTime = now;

      setGameNotes(prevNotes => {
        let isAnyLeft = false;
        const updated = prevNotes.map(n => {
          if (n.y < 550) {
            isAnyLeft = true;
            return { ...n, y: n.y + (180 * speedMult * delta) }; // Falling down
          } else if (!n.hasHit && n.y >= 550 && n.y < 600) {
            // Automatically mark missed when passing keyboard bottom bounds
            setGameFeedback('MISS');
            setGameCombo(0);
            return { ...n, y: 1000, hasHit: true }; // Missed note goes away
          }
          return n;
        });

        if (!isAnyLeft) {
          // Game Ended
          setGamePlaying(false);
        }
        return updated;
      });

      if (gamePlaying) {
        gameLoopRef.current = requestAnimationFrame(runLoop);
      }
    };

    gameLoopRef.current = requestAnimationFrame(runLoop);
  };

